{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dispatch_contract.v1.json",
  "title": "Bounded Planner to Implementer dispatch",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id", "mode", "permitted_read_paths", "permitted_write_paths", "approved_command_ids", "acceptance_checks", "stop_conditions"],
  "properties": {
    "contract_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["implement", "verify", "no_mutation"]},
    "permitted_read_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "permitted_write_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "approved_command_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "acceptance_checks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "stop_conditions": {"type": "array", "items": {"type": "string"}},
    "approval_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
