{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "policy_extension.v1.json",
  "title": "User-supplied behavioural or deterministic policy extension",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_id", "summary", "enforcement_layer", "applicability", "evidence_required"],
  "properties": {
    "policy_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
    "summary": {"type": "string", "minLength": 1},
    "enforcement_layer": {"enum": ["advisory", "learned", "deterministic", "learned_and_deterministic"]},
    "applicability": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "evidence_required": {"type": "array", "items": {"type": "string"}},
    "forbidden_outcomes": {"type": "array", "items": {"type": "string"}}
  }
}
